<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--
    login.fxml
    Simple, professional login screen.
    Bound to com.hotel.controller.LoginController.
-->
<VBox alignment="CENTER" spacing="25" prefWidth="420" prefHeight="360"
      style="-fx-background-color: #f4f6f8;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hotel.controller.LoginController">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <!-- Title -->
    <Label text="Hotel Management System"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Label text="Please sign in to continue"
           style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>

    <GridPane hgap="10" vgap="15" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="80"/>
            <ColumnConstraints minWidth="220"/>
        </columnConstraints>

        <!-- Username -->
        <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="usernameField" promptText="Enter username"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <!-- Password -->
        <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <PasswordField fx:id="passwordField" promptText="Enter password"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>

    <!-- Buttons -->
    <HBox alignment="CENTER" spacing="15">
        <Button fx:id="loginButton" text="Login" defaultButton="true"
                style="-fx-background-color: #2c7be5; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 100;"
                onAction="#handleLoginButtonAction"/>
        <Button fx:id="exitButton" text="Exit" cancelButton="true"
                style="-fx-background-color: #e63946; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 100;"
                onAction="#handleExitButtonAction"/>
    </HBox>

</VBox>
